      "doctor_tablet": "https://images.unsplash.com/photo-1536064479547-7ee40b74b807?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjY2NzN8MHwxfHNlYXJjaHwyfHxibGFjayUyMGRvY3RvciUyMHRhYmxldCUyMGhvc3BpdGFsfGVufDB8fHx8MTc3MjkzNzc1Nnww&ixlib=rb-4.1.0&q=85",
      "microscope": "https://images.unsplash.com/photo-1738778151587-032287ae9f90?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA1NzR8MHwxfHNlYXJjaHw0fHxtaWNyb3Njb3BlJTIwc2NpZW5jZSUyMGxhYnxlbnwwfHx8fDE3NzI5Mzc3NTh8MA&ixlib=rb-4.1.0&q=85",
      "abstract_dna": "https://images.unsplash.com/photo-1621402705959-fe90b5c9b42c?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA1NzB8MHwxfHNlYXJjaHw0fHxETkElMjBzZXF1ZW5jaW5nJTIwZGF0YSUyMHZpc3VhbGl6YXRpb24lMjBhYnN0cmFjdCUyMGxpZ2h0JTIwYmFja2dyb3VuZHxlbnwwfHx8fDE3NzI5Mzc3MzR8MA&ixlib=rb-4.1.0&q=85"
    },
    "icons": {
      "library": "lucide-react",
      "style": "Stroke width 1.5px (Thin/Technical)"
    }
  },
  "instructions_to_main_agent": [
    "1. INIT: Create a new React project in /app if not present (or restructure existing).",
    "2. SETUP: Install 'lucide-react', 'framer-motion', 'recharts', 'clsx', 'tailwind-merge'.",
    "3. CLEANUP: Remove any existing static HTML files in the root if they conflict with the React app.",
    "4. COMPONENTS: Build 'ui/card', 'ui/button' (pill shape), 'ui/badge' (for status).",
    "5. NAV: Create a sticky glassmorphic header.",
    "6. PAGES: Implement the 5 core pages defined in 'pages' section.",
    "7. DATA VIZ: Use Recharts for the AMR Intelligence graphs. Mock the data.",
    "8. ANIMATION: Add simple entrance animations (fade-in-up) to all text blocks."
  ],
  "universal_guidelines": [
    "NEVER use generic 'Lorem Ipsum'. Use realistic medical data (e.g., 'Klebsiella pneumoniae', 'Resistance Gene blaNDM-1').",
    "Ensure Mobile Responsiveness: Stack bento grids to single column on mobile.",
    "Use 'border-slate-200' for all borders to maintain the 'Light/Clinical' feel.",
    "Do NOT use heavy drop shadows. Use 'shadow-sm' at most.",
    "Interactive elements must have a 'data-testid' for testing."
  ]
}